doctype html
html(lang='tr')
    head
        meta(charset='UTF-8')
        meta(name='viewport', content='width=device-width, initial-scale=1.0')
        title= title
        link(rel="icon", type="image/png", href="favicon.ico")
    body
        .container
            // Header
            header.header
                h1 📺 IPTV Recorder
                .status-indicator(class=status ? 'recording' : '')
                    span.dot
                    span=status ? 'Kayıt Başladı' : 'Hazır'

            // Recording Control
            if status
                .recording-bar
                    .info
                        strong Kayıt Aktif:
                        span.channel-name= currentJob ? currentJob.channelName : ''
                    form(action="/stop", method="POST").stop-form
                        input(type="submit", value='⏹ Durdur')

            // Conversion Status
            if isConverting
                .converting-bar
                    .info
                        strong Dönüştürülüyor:
                        span.channel-name= convertingJob ? convertingJob.channelName : ''
                    span.converting-indicator ⏳

            // Add Job Form

            // Add Job Form
            .card
                form(action="/addJob", method="POST", id='addJobForm')
                    .form-group
                        label Kanal
                        .autocomplete-wrapper
                            input#channelName(name='channelName', type='text', placeholder='Kanal adı yazın (min 3 harf)...', required, autocomplete='off')
                            ul#channelSuggestions.channel-suggestions
                                // Javascript ile doldurulacak

                    .form-row
                        .form-group.half
                            label Başlangıç
                            input#startDate(name='startDate', type='datetime-local', required)
                        .form-group.half
                            label Bitiş
                            input#endDate(name='endDate', type='datetime-local', required)

                    .presets
                        span Preset:
                        button(type='button', data-preset='now1h') Şimdi + 1s
                        button(type='button', data-preset='today20') Bugün 20:00
                        button(type='button', data-preset='tomorrow20') Yarın 20:00
                        button(type='button', data-preset='now2h') Şimdi + 2s
                        button(type='button', data-preset='now3h') Şimdi + 3s

                    .form-actions
                        input(type='submit', value='💾 Kaydet')

            // Filters
            .filters
                .filter-group
                    label Durum:
                    select#filterStatus
                        option(value='all') Tümü
                        option(value='pending') Bekleyen
                        option(value='completed') Tamamlanan
                        option(value='error') Hatalı

            // Jobs Table
            .jobs-section
                table.jobs-table
                    thead
                        tr
                            th Kanal
                            th Başlangıç
                            th Bitiş
                            th Kalan Süre
                            th Durum
                            th HLS Boyutu
                            th MP4 Boyutu
                            th İşlemler
                    tbody#jobsBody
                        each job in jobs
                            - var isActuallyRecording = currentJob && currentJob.id === job.id
                            - var isRecording = isActuallyRecording || (job.status && !job.record)
                            - var isCompleted = job.status && job.record === 'SUCCESS'
                            - var isError = job.record === 'ERROR'
                            - var isPending = !job.status && !job.record
                            - var isConverting = isCompleted && !job.mp4Path
                            - var willRetry = isError && job.count < 5 // assuming maxRetryCount=5
                            - var rowClass = isActuallyRecording ? 'row-recording' : (isCompleted ? 'row-completed' : (isError ? 'row-error' : 'row-pending'))
                            - var statusType = isCompleted ? 'completed' : (isError ? 'error' : 'pending')
                            - var badgeClass = isActuallyRecording ? 'badge-recording' : (isCompleted ? 'badge-success' : (isError ? 'badge-error' : 'badge-pending'))
                            - var statusText = isActuallyRecording ? 'KAYIT' : (isCompleted ? 'TAMAM' : (isError ? (willRetry ? 'HATA Tekrar: ' + job.count : 'HATA') : 'BEKLE'))
                            - var startDate = new Date(job.startTimestamp)
                            - var endDate = new Date(job.endTimestamp)
                            - var startDateStr = startDate.toLocaleString('tr-TR', {day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit'})
                            - var endDateStr = endDate.toLocaleString('tr-TR', {day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit'})
                            tr(class=rowClass, data-status=statusType, data-channel=job.channelName)
                                td.channel-cell= job.channelName
                                td= startDateStr
                                td= endDateStr
                                td.countdown-cell(data-start=job.startTimestamp, data-end=job.endTimestamp, data-status=job.status, data-record=job.record || '', data-channel=job.channelName)
                                td.status-cell
                                    span.badge(class=badgeClass)= statusText
                                    if isError && job.count
                                        span.retry-count (#{job.count}/5)
                                    if isConverting
                                        span.converting-badge ⏳ Dönüştürülüyor...
                                td.hls-size= job.fileSize || '-'
                                td.mp4-size
                                    if job.mp4Path
                                        span= job.mp4FileSize || '-'
                                    else if isCompleted
                                        - var jobEnd = new Date(job.endTimestamp)
                                        - var minutesSinceEnd = Math.floor((Date.now() - jobEnd.getTime()) / 60000)
                                        if minutesSinceEnd > 5
                                            span.convert-timeout ⚠ Conversion timeout (#{minutesSinceEnd}dk)
                                        else
                                            span.convert-pending Bekliyor... (#{Math.min(5 - minutesSinceEnd, 5)}dk)
                                    else
                                        span -
                                td.actions
                                    if isPending || willRetry
                                        if !isActuallyRecording
                                            form.start-form(action="/startJob", method="POST")
                                                input(name="id", type="hidden", value=job.id)
                                                button.start-btn(type='submit', title='Başlat') ▶
                                        form.delete-form(action="/deleteJob", method="POST")
                                            input(name="id", type="hidden", value=job.id)
                                            button.delete-btn(type='submit', title='Sil') 🗑
                                    else if isActuallyRecording
                                        a.live-watch-btn(href='/play?id=' + job.id, target='_blank', title='Canlı İzle') 🔴 CANLI
                                    else if isCompleted && job.mp4Path
                                        a.watch-btn(href='/play?id=' + job.id, target='_blank', title='İzle') ▶ İzle
                                        form.delete-form(action="/deleteJob", method="POST")
                                            input(name="id", type="hidden", value=job.id)
                                            button.delete-btn(type='submit', title='Sil') 🗑
        style.
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
                background: #1a1a2e;
                color: #eee;
                padding: 20px;
                line-height: 1.5;
            }

            .container {
                max-width: 1200px;
                margin: 0 auto;
            }

            /* Header */
            .header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 20px;
                background: #16213e;
                border-radius: 12px;
                margin-bottom: 20px;
            }

            .header h1 {
                font-size: 1.8rem;
            }

            .status-indicator {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 10px 20px;
                background: #2d2d44;
                border-radius: 20px;
            }

            .status-indicator.recording {
                background: #1a4d2e;
            }

            .dot {
                width: 10px;
                height: 10px;
                background: #666;
                border-radius: 50%;
                animation: pulse 2s infinite;
            }

            .status-indicator.recording .dot {
                background: #00ff88;
            }

            @keyframes pulse {
                0%, 100% {
                    opacity: 1;
                }
                50% {
                    opacity: 0.5;
                }
            }

            /* Recording Bar */
            .recording-bar {
                display: flex;
                justify-content: space-between;
                align-items: center;
                background: linear-gradient(135deg, #1a4d2e, #0f3820);
                padding: 15px 20px;
                border-radius: 12px;
                margin-bottom: 20px;
            }

            .recording-bar .channel-name {
                color: #00ff88;
                margin-left: 10px;
            }

            .stop-form {
                margin: 0;
            }

            .stop-form input[type="submit"] {
                background: #ff4444;
                color: white;
                border: none;
                padding: 10px 20px;
                border-radius: 8px;
                cursor: pointer;
                font-weight: bold;
            }

            .stop-form input[type="submit"]:hover {
                background: #cc0000;
            }

            /* Converting Bar */
            .converting-bar {
                display: flex;
                justify-content: space-between;
                align-items: center;
                background: linear-gradient(135deg, #1a3d4d, #0f2838);
                padding: 15px 20px;
                border-radius: 12px;
                margin-bottom: 20px;
            }

            .converting-bar .channel-name {
                color: #00d4ff;
                margin-left: 10px;
            }

            .converting-indicator {
                color: #00d4ff;
                font-size: 1.2rem;
                animation: spin 2s linear infinite;
            }

            @keyframes spin {
                from { transform: rotate(0deg); }
                to { transform: rotate(360deg); }
            }

            /* Card */
            .card {
                background: #16213e;
                border-radius: 12px;
                padding: 25px;
                margin-bottom: 20px;
            }

            .card h2 {
                margin-bottom: 20px;
                color: #00d4ff;
            }

            /* Form */
            #addJobForm {
                display: grid;
                gap: 15px;
            }

            .form-group {
                display: flex;
                flex-direction: column;
                gap: 5px;
            }

            .form-group.half {
                flex: 1;
            }

            .form-row {
                display: flex;
                gap: 15px;
            }

            label {
                font-weight: 600;
                color: #aaa;
                font-size: 0.9rem;
            }

            #channelName {
                width: 100%;
                padding: 12px;
                background: #0d1b2a;
                border: 1px solid #2d4a6f;
                border-radius: 8px;
                color: #eee;
                font-size: 1rem;
            }

            .autocomplete-wrapper {
                position: relative;
            }

            .channel-suggestions {
                position: absolute;
                top: 100%;
                left: 0;
                right: 0;
                max-height: 250px;
                overflow-y: auto;
                background: #16213e;
                border: 1px solid #2d4a6f;
                border-radius: 0 0 8px 8px;
                list-style: none;
                margin: 0;
                padding: 0;
                z-index: 1000;
                display: none;
            }

            .channel-suggestions.show {
                display: block;
            }

            .channel-suggestions li {
                padding: 10px 12px;
                cursor: pointer;
                border-bottom: 1px solid #2d4a6f;
                transition: background 0.2s;
            }

            .channel-suggestions li:last-child {
                border-bottom: none;
            }

            .channel-suggestions li:hover {
                background: #2d4a6f;
            }

            .channel-suggestions li:active {
                background: #3d5a7f;
            }

            .channel-suggestions::-webkit-scrollbar {
                width: 8px;
            }

            .channel-suggestions::-webkit-scrollbar-track {
                background: #0d1b2a;
            }

            .channel-suggestions::-webkit-scrollbar-thumb {
                background: #2d4a6f;
                border-radius: 4px;
            }

            .channel-suggestions::-webkit-scrollbar-thumb:hover {
                background: #3d5a7f;
            }

            .suggestions-empty {
                padding: 10px 12px;
                color: #666;
                font-style: italic;
            }

            input[type="datetime-local"] {
                width: 100%;
                padding: 12px;
                background: #0d1b2a;
                border: 1px solid #2d4a6f;
                border-radius: 8px;
                color: #eee;
                font-size: 1rem;
                cursor: pointer;
            }

            .presets {
                display: flex;
                gap: 8px;
                flex-wrap: wrap;
                align-items: center;
            }

            .presets span {
                color: #aaa;
                margin-right: 5px;
            }

            .presets button {
                background: #2d4a6f;
                color: #eee;
                border: none;
                padding: 8px 14px;
                border-radius: 6px;
                cursor: pointer;
                font-size: 0.85rem;
                transition: background 0.2s;
            }

            .presets button:hover {
                background: #3d5a7f;
            }

            .form-actions {
                margin-top: 10px;
            }

            input[type="submit"] {
                background: linear-gradient(135deg, #00d4ff, #0099cc);
                color: #000;
                border: none;
                padding: 14px 30px;
                border-radius: 8px;
                cursor: pointer;
                font-weight: bold;
                font-size: 1rem;
                width: 100%;
                transition: transform 0.2s;
            }

            input[type="submit"]:hover {
                transform: scale(1.02);
            }

            /* Filters */
            .filters {
                display: flex;
                gap: 20px;
                flex-wrap: wrap;
                padding: 15px 20px;
                background: #16213e;
                border-radius: 12px;
                margin-bottom: 20px;
            }

            .filter-group {
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .filter-group select {
                padding: 8px 12px;
                background: #0d1b2a;
                border: 1px solid #2d4a6f;
                border-radius: 6px;
                color: #eee;
                cursor: pointer;
            }

            /* Jobs Table */
            .jobs-section h2 {
                margin-bottom: 15px;
                color: #00d4ff;
            }

            .jobs-table {
                width: 100%;
                border-collapse: collapse;
                background: #16213e;
                border-radius: 12px;
                overflow: hidden;
            }

            .jobs-table thead {
                background: #0d1b2a;
            }

            .jobs-table th {
                padding: 15px;
                text-align: left;
                font-weight: 600;
                color: #aaa;
                border-bottom: 1px solid #2d4a6f;
            }

            .jobs-table td {
                padding: 12px 15px;
                border-bottom: 1px solid #2d4a6f;
            }

            .jobs-table tr:last-child td {
                border-bottom: none;
            }

            .jobs-table tbody tr {
                transition: background 0.2s;
            }

            .jobs-table tbody tr:hover {
                background: #1a2a4e;
            }

            .jobs-table tbody tr.row-completed {
                background: rgba(0, 255, 136, 0.05);
            }

            .jobs-table tbody tr.row-error {
                background: rgba(255, 68, 68, 0.05);
            }

            .jobs-table tbody tr.row-pending {
            }

            .jobs-table tbody tr.row-recording {
                background: rgba(0, 212, 255, 0.1);
                border-left: 3px solid #00d4ff;
            }

            .channel-cell {
                font-weight: 600;
                color: #00d4ff;
            }

            .badge {
                padding: 5px 12px;
                border-radius: 12px;
                font-size: 0.8rem;
                font-weight: 600;
                text-transform: uppercase;
            }

            .badge-success {
                background: #1a4d2e;
                color: #00ff88;
            }

            .badge-error {
                background: #4d1a1a;
                color: #ff4444;
            }

            .badge-pending {
                background: #4d4a1a;
                color: #ffcc00;
            }

            .badge-recording {
                background: #1a4d2e;
                color: #00ff88;
                animation: pulse-badge 1.5s infinite;
            }

            @keyframes pulse-badge {
                0%, 100% { opacity: 1; }
                50% { opacity: 0.7; }
            }

            .retry-count {
                margin-left: 5px;
                font-size: 0.75rem;
                color: #ff4444;
            }

            .converting-badge {
                margin-left: 8px;
                font-size: 0.75rem;
                color: #00d4ff;
                animation: pulse 1.5s infinite;
            }

            .convert-pending {
                color: #666;
                font-size: 0.85rem;
                font-style: italic;
            }

            .convert-timeout {
                color: #ffcc00;
                font-size: 0.8rem;
                font-weight: 600;
            }

            .play-link {
                margin-left: 8px;
                color: #00ff88;
                text-decoration: none;
                font-size: 1rem;
                transition: transform 0.2s;
                display: inline-block;
            }

            .play-link:hover {
                transform: scale(1.2);
            }

            .watch-btn {
                margin-right: 8px;
                color: #00ff88;
                text-decoration: none;
                font-size: 1.2rem;
                transition: transform 0.2s;
                display: inline-block;
            }

            .watch-btn:hover {
                transform: scale(1.2);
            }

            .live-watch-btn {
                margin-right: 8px;
                color: #fff;
                background: linear-gradient(135deg, #ff4444, #cc0000);
                text-decoration: none;
                font-size: 0.8rem;
                font-weight: bold;
                padding: 6px 12px;
                border-radius: 6px;
                transition: transform 0.2s, background 0.2s;
                display: inline-block;
                animation: pulse-live 1.5s infinite;
            }

            @keyframes pulse-live {
                0%, 100% { opacity: 1; }
                50% { opacity: 0.8; }
            }

            .live-watch-btn:hover {
                transform: scale(1.05);
                background: linear-gradient(135deg, #ff6666, #ee0000);
            }

            .countdown-cell {
                font-family: monospace;
                color: #aaa;
                font-size: 0.9rem;
            }

            .countdown-active {
                color: #00d4ff;
                font-weight: bold;
            }

            .countdown-soon {
                color: #ffcc00;
            }

            .countdown-error {
                color: #ff4444;
            }

            .actions {
                white-space: nowrap;
            }

            .start-form, .delete-form, .stop-form {
                display: inline;
            }

            .delete-btn {
                background: transparent;
                border: none;
                font-size: 1.2rem;
                cursor: pointer;
                padding: 5px;
                transition: transform 0.2s;
            }

            .delete-btn:hover {
                transform: scale(1.2);
            }

            .start-btn {
                background: #1a4d2e;
                color: #00ff88;
                border: none;
                font-size: 1rem;
                cursor: pointer;
                padding: 5px 10px;
                border-radius: 6px;
                transition: background 0.2s;
                margin-right: 5px;
            }

            .start-btn:hover {
                background: #0f3820;
            }

            /* Bulk Actions */
            .bulk-actions {
                display: flex;
                gap: 15px;
                align-items: center;
                margin-top: 15px;
            }

            .clean-btn {
                background: #2d4a6f;
                color: #eee;
                border: none;
                padding: 10px 20px;
                border-radius: 8px;
                cursor: pointer;
                transition: background 0.2s;
            }

            .clean-btn:hover {
                background: #3d5a7f;
            }

            .total-jobs {
                color: #aaa;
                font-size: 0.9rem;
            }

            /* Hidden rows */
            .hidden-row {
                display: none;
            }

            /* Responsive */
            @media (max-width: 768px) {
                .header {
                    flex-direction: column;
                    gap: 15px;
                    text-align: center;
                }

                .form-row {
                    flex-direction: column;
                }

                .jobs-table {
                    font-size: 0.85rem;
                }

                .jobs-table th, .jobs-table td {
                    padding: 8px;
                }
            }

    script.
        document.addEventListener('DOMContentLoaded', function () {
            // Channel autocomplete
            const channelInput = document.getElementById('channelName');
            const channelSuggestions = document.getElementById('channelSuggestions');
            let searchTimeout;

            function closeSuggestions() {
                channelSuggestions.classList.remove('show');
            }

            function showSuggestions(channels) {
                if (channels.length === 0) {
                    channelSuggestions.innerHTML = '<li class="suggestions-empty">Sonuç bulunamadı</li>';
                } else {
                    channelSuggestions.innerHTML = channels.map(ch => `<li>${ch}</li>`).join('');
                }
                channelSuggestions.classList.add('show');

                // Add click handlers to suggestions
                channelSuggestions.querySelectorAll('li:not(.suggestions-empty)').forEach(li => {
                    li.addEventListener('click', function () {
                        channelInput.value = this.textContent;
                        closeSuggestions();
                    });
                });
            }

            // Close suggestions when clicking outside
            document.addEventListener('click', function (e) {
                if (!e.target.closest('.autocomplete-wrapper')) {
                    closeSuggestions();
                }
            });

            // Handle keyboard navigation
            channelInput.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    closeSuggestions();
                }
            });

            if (channelInput) {
                channelInput.addEventListener('input', function () {
                    const query = this.value.trim();
                    clearTimeout(searchTimeout);

                    if (query.length < 3) {
                        closeSuggestions();
                        return;
                    }

                    searchTimeout = setTimeout(async () => {
                        try {
                            const res = await fetch(`/api/channels/search?q=${encodeURIComponent(query)}`);
                            const data = await res.json();
                            showSuggestions(data.channels);
                        } catch (e) {
                            console.error('Kanal arama hatası:', e);
                        }
                    }, 300);
                });
            }

            // Date presets
            const startDate = document.getElementById('startDate');
            const endDate = document.getElementById('endDate');

            function setDateTimeLocal(input, date) {
                date.setMinutes(date.getMinutes() - date.getTimezoneOffset());
                input.value = date.toISOString().slice(0, 16);
            }

            if (startDate && endDate) {
                const now = new Date();

                // Set min dates
                setDateTimeLocal(startDate, new Date());
                setDateTimeLocal(endDate, new Date());

                // Set default values
                const startDefault = new Date(now.getTime() + 10 * 60000);
                const endDefault = new Date(now.getTime() + 130 * 60000);
                setDateTimeLocal(startDate, startDefault);
                setDateTimeLocal(endDate, endDefault);

                // Preset buttons
                document.querySelectorAll('.presets button').forEach(btn => {
                    btn.addEventListener('click', function () {
                        const preset = this.dataset.preset;
                        const now = new Date();

                        switch (preset) {
                            case 'now1h':
                                setDateTimeLocal(startDate, new Date(now.getTime() + 60000));
                                setDateTimeLocal(endDate, new Date(now.getTime() + 60 * 60000 + 60000));
                                break;
                            case 'now2h':
                                setDateTimeLocal(startDate, new Date(now.getTime() + 60000));
                                setDateTimeLocal(endDate, new Date(now.getTime() + 120 * 60000 + 60000));
                                break;
                            case 'now3h':
                                setDateTimeLocal(startDate, new Date(now.getTime() + 60000));
                                setDateTimeLocal(endDate, new Date(now.getTime() + 180 * 60000 + 60000));
                                break;
                            case 'today20':
                                const today20 = new Date(now);
                                today20.setHours(20, 0, 0, 0);
                                if (today20 <= now) today20.setDate(today20.getDate() + 1);
                                setDateTimeLocal(startDate, today20);
                                setDateTimeLocal(endDate, new Date(today20.getTime() + 120 * 60000));
                                break;
                            case 'tomorrow20':
                                const tomorrow20 = new Date(now);
                                tomorrow20.setDate(tomorrow20.getDate() + 1);
                                tomorrow20.setHours(20, 0, 0, 0);
                                setDateTimeLocal(startDate, tomorrow20);
                                setDateTimeLocal(endDate, new Date(tomorrow20.getTime() + 120 * 60000));
                                break;
                        }
                    });
                });
            }

            // Countdown timer
            function formatCountdown(ms) {
                if (ms < 0) return 'Geçmiş';
                const seconds = Math.floor(ms / 1000);
                const minutes = Math.floor(seconds / 60);
                const hours = Math.floor(minutes / 60);
                const days = Math.floor(hours / 24);

                if (days > 0) return `${days}g ${hours % 24}s`;
                if (hours > 0) return `${hours}s ${minutes % 60}d`;
                if (minutes > 0) return `${minutes}d ${seconds % 60}s`;
                return `${seconds}s`;
            }

            function updateCountdowns() {
                document.querySelectorAll('.countdown-cell').forEach(cell => {
                    const start = new Date(cell.dataset.start);
                    const end = new Date(cell.dataset.end);
                    const status = cell.dataset.status === 'true';
                    const record = cell.dataset.record;
                    const channelId = cell.dataset.channel;
                    const now = new Date();

                    cell.classList.remove('countdown-active', 'countdown-soon');

                    // Check if this is the currently recording job (by channel name)
                    const recordingBar = document.querySelector('.recording-bar');
                    const isCurrentlyRecording = recordingBar && recordingBar.querySelector('.channel-name');
                    const recordingChannel = isCurrentlyRecording ? isCurrentlyRecording.textContent.trim() : null;

                    cell.classList.remove('countdown-active', 'countdown-soon');

                    // Completed job
                    if (record === 'SUCCESS') {
                        cell.textContent = '✓ Tamamlandı';
                        return;
                    }

                    // Error job
                    if (record === 'ERROR') {
                        cell.textContent = '⚠ Hatalı';
                        cell.classList.add('countdown-error');
                        return;
                    }

                    // Currently recording (check by channel name match)
                    if ((status && record !== 'SUCCESS' && record !== 'ERROR') ||
                        (recordingChannel && channelId === recordingChannel)) {
                        const remaining = end - now;
                        if (remaining > 0) {
                            cell.textContent = '● Kayıt: ' + formatCountdown(remaining);
                            cell.classList.add('countdown-active');
                        } else {
                            cell.textContent = 'Tamamlandı';
                        }
                        return;
                    }

                    // Waiting to start
                    const untilStart = start - now;
                    if (untilStart > 0) {
                        cell.textContent = 'Başlamasına: ' + formatCountdown(untilStart);
                        if (untilStart < 30 * 60000) {
                            cell.classList.add('countdown-soon');
                        }
                    } else if (untilStart <= 0 && end > now) {
                        // Should be recording but hasn't started yet
                        cell.textContent = 'Başlıyor...';
                        cell.classList.add('countdown-active');
                    } else {
                        cell.textContent = 'Geçmiş';
                    }
                });
            }

            updateCountdowns();
            setInterval(updateCountdowns, 1000);

            // Filters
            const filterStatus = document.getElementById('filterStatus');

            if (filterStatus) {
                function applyFilters() {
                    const statusFilter = filterStatus.value;

                    document.querySelectorAll('#jobsBody tr').forEach(row => {
                        const rowStatus = row.dataset.status;

                        let show = true;
                        if (statusFilter !== 'all' && rowStatus !== statusFilter) show = false;

                        row.classList.toggle('hidden-row', !show);
                    });
                }

                filterStatus.addEventListener('change', applyFilters);
            }

            // Delete confirmation
            document.querySelectorAll('.delete-form').forEach(form => {
                form.addEventListener('submit', function (e) {
                    if (!confirm('Bu kaydı silmek istediğinizden emin misiniz?')) {
                        e.preventDefault();
                    }
                });
            });
        });
